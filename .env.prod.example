# Скопируй в .env.prod и заполни своими значениями.
# .env.prod в git НЕ коммитится (он в .gitignore).

# Домен (A-запись домена должна указывать на IP этого сервера)
DOMAIN=crm.example.com

# Postgres
POSTGRES_USER=crm
POSTGRES_PASSWORD=ЗАМЕНИ_на_надёжный_пароль
POSTGRES_DB=crm

# Секрет для подписи JWT. Сгенерируй:  openssl rand -hex 32
JWT_SECRET=ЗАМЕНИ_на_длинную_случайную_строку

# Первый суперадмин (создаётся при первом старте бэкенда)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ЗАМЕНИ_пароль_админа
SUPERADMIN_NAME=Super Admin
